<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@color/background">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="System Administration"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/on_background"
        android:layout_marginBottom="24dp"/>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@color/surface">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Data Management"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/primary"/>

            <Button
                android:id="@+id/btnExportData"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Export All System Data"
                android:layout_marginTop="16dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="System Maintenance"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/error"
                android:layout_marginTop="32dp"/>

            <Button
                android:id="@+id/btnClearSystem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Clear All Database Records"
                android:layout_marginTop="16dp"
                android:textColor="@color/error"
                app:strokeColor="@color/error"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Note: Admin functions require a valid X-Admin-Token set in Settings."
        android:layout_marginTop="24dp"
        android:gravity="center"
        android:textSize="12sp"
        android:textColor="@color/primary"/>

</LinearLayout>
